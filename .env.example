# Copy to .env for local dev. In production set these as real environment variables.

# Required everywhere — a long random string (e.g. `openssl rand -hex 32`)
PAYLOAD_SECRET=generate-a-long-random-string

# Database.
#  - Local dev (SQLite, default):  file:./kennel.db
#  - Production (Postgres/Neon):   postgres://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URI=file:./kennel.db

# Production photo storage (Vercel Blob). Leave unset locally to store photos on disk.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Seeding (POST /api/seed?secret=...)
SEED_SECRET=generate-a-random-string
SEED_ADMIN_EMAIL=kimberlylabradoodlekennel@gmail.com
SEED_ADMIN_PASSWORD=ChangeMe123!
